{
  "name": "passionfruit",
  "version": "0.1.0",
  "description": "Everyone can cook. Professional websites for everyone, powered by Claude Code.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/check-bilingual.mjs",
    "build": "pnpm lint && pnpm typecheck && astro build",
    "preview": "astro preview",
    "typecheck": "astro check --minimumSeverity warning && tsc --noEmit",
    "lint": "eslint --fix --cache --cache-location .cache/eslint . && prettier --write .",
    "lint:a11y": "eslint --config eslint.astro.config.mjs 'src/**/*.astro'",
    "test": "node --test scripts/check-bilingual.test.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@fontsource-variable/inter": "^5.2.5",
    "@lucide/astro": "^1.11.0",
    "astro": "^6.1.10",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}

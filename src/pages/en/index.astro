---
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Button from "~/components/Button.astro";
import FAQ from "~/components/sections/FAQ.astro";
import { useTranslations, getLocalizedPath } from "~/i18n";
import { getTestimonials } from "~/data/testimonials";
import { getFAQs } from "~/data/faqs";
import { Palette, Code, Lightbulb, ArrowRight, Quote } from "@lucide/astro";
import heroImage from "~/assets/home/hero.png";

const lang = "en" as const;
const { t } = useTranslations(lang);
const testimonials = getTestimonials(lang);
const faqItems = getFAQs(lang);
const contactHref = getLocalizedPath("contact", lang);
const servicesHref = getLocalizedPath("services", lang);
---

<BaseLayout
  title={t("site.name")}
  description={t("site.description")}
  lang={lang}
  headerVariant="on-dark"
>
  <!-- ═══════════ HERO ═══════════ -->
  <section
    class="relative min-h-dvh flex items-center overflow-hidden bg-surface-dark noise"
  >
    <div class="absolute inset-0">
      <div
        class="glow-orb absolute top-1/4 -left-32 w-[500px] h-[500px] rounded-full bg-accent/20 blur-[120px]"
      >
      </div>
      <div
        class="glow-orb absolute bottom-1/4 right-0 w-[400px] h-[400px] rounded-full bg-warm/15 blur-[100px]"
        style="animation-delay: 4s"
      >
      </div>
      <div class="absolute inset-0 bg-grid opacity-30"></div>
    </div>

    <div class="container relative z-10 py-24 md:py-0">
      <div
        class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center min-h-[80dvh]"
      >
        <div class="max-w-2xl">
          <p class="eyebrow hero-stagger" style="--delay: 100ms">
            {t("site.name")}
          </p>
          <h1
            class="text-display text-text-on-dark mt-6 hero-stagger"
            style="--delay: 200ms"
          >
            {t("home.hero.headline").split(" ").slice(0, -1).join(" ")}{" "}
            <span class="gradient-text"
              >{t("home.hero.headline").split(" ").at(-1)}</span
            >
          </h1>
          <p
            class="text-body-lg text-text-on-dark/60 mt-6 max-w-lg hero-stagger"
            style="--delay: 400ms"
          >
            {t("home.hero.subheadline")}
          </p>
          <div
            class="flex flex-wrap gap-4 mt-10 hero-stagger"
            style="--delay: 600ms"
          >
            <Button
              href={contactHref}
              variant="primary"
              tone="on-dark"
              class="btn-glow group"
            >
              {t("home.hero.cta")}
              <ArrowRight
                class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1"
              />
            </Button>
            <Button href={servicesHref} variant="secondary" tone="on-dark">
              {t("services.title")}
            </Button>
          </div>
        </div>

        <div
          class="relative hero-stagger hidden lg:block"
          style="--delay: 500ms"
        >
          <div
            class="absolute -inset-8 rounded-[2rem] bg-gradient-to-br from-accent/20 via-transparent to-warm/20 blur-2xl"
          >
          </div>
          <Image
            src={heroImage}
            alt=""
            class="relative rounded-2xl shadow-2xl shadow-accent/10 ring-1 ring-white/10"
            widths={[400, 600, 800]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 hero-stagger"
      style="--delay: 1000ms"
    >
      <div
        class="w-5 h-8 rounded-full border-2 border-text-on-dark/20 flex justify-center pt-1.5"
      >
        <div class="w-1 h-2 rounded-full bg-text-on-dark/40 animate-bounce">
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURES ═══════════ -->
  <section class="relative py-28 md:py-40 bg-grid">
    <div class="container">
      <div class="max-w-2xl anim-slide-up">
        <p class="eyebrow">{t("services.title")}</p>
        <h2 class="text-h2 text-text-heading mt-4">
          {t("home.features.title")}
        </h2>
        <p class="text-body-lg text-muted mt-4">
          {t("home.features.subtitle")}
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-16">
        <div class="card anim-card-enter" style="--delay: 0ms">
          <div
            class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-6"
          >
            <Palette class="w-6 h-6 text-accent" />
          </div>
          <h3 class="text-h3 text-text-heading">
            {t("services.webDesign.title")}
          </h3>
          <p class="text-muted mt-3 leading-relaxed">
            {t("services.webDesign.description")}
          </p>
        </div>
        <div class="card anim-card-enter" style="--delay: 100ms">
          <div
            class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-6"
          >
            <Code class="w-6 h-6 text-accent" />
          </div>
          <h3 class="text-h3 text-text-heading">
            {t("services.development.title")}
          </h3>
          <p class="text-muted mt-3 leading-relaxed">
            {t("services.development.description")}
          </p>
        </div>
        <div class="card anim-card-enter" style="--delay: 200ms">
          <div
            class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-6"
          >
            <Lightbulb class="w-6 h-6 text-accent" />
          </div>
          <h3 class="text-h3 text-text-heading">
            {t("services.consulting.title")}
          </h3>
          <p class="text-muted mt-3 leading-relaxed">
            {t("services.consulting.description")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS ═══════════ -->
  <section
    class="py-28 md:py-40 bg-surface-dark noise relative overflow-hidden"
  >
    <div
      class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-accent/10 blur-[150px] -translate-y-1/2 translate-x-1/3"
    >
    </div>
    <div class="container relative z-10">
      <div class="text-center anim-slide-up">
        <p class="eyebrow text-accent-glow">{t("home.testimonials.title")}</p>
        <h2 class="text-h2 text-text-on-dark mt-4">
          {t("home.testimonials.title")}
        </h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 max-w-4xl mx-auto mt-16">
        {
          testimonials.map((item, i) => (
            <div
              class="glass p-8 anim-card-enter"
              style={`--delay: ${i * 150}ms`}
            >
              <Quote class="w-8 h-8 text-accent-glow/40 mb-4" />
              <p class="text-text-on-dark/80 text-body-lg leading-relaxed">
                {item.quote}
              </p>
              <div class="mt-6 pt-6 border-t border-white/10">
                <p class="text-text-on-dark font-semibold">{item.author}</p>
                <p class="text-text-on-dark/50 text-sm">{item.company}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════ FAQs ═══════════ -->
  <FAQ headline={t("home.faq.title")} items={faqItems} />

  <!-- ═══════════ CTA ═══════════ -->
  <section
    class="relative py-28 md:py-40 bg-surface-dark noise overflow-hidden"
  >
    <div class="absolute inset-0">
      <div
        class="glow-orb absolute top-1/2 left-1/4 w-[500px] h-[500px] rounded-full bg-accent/15 blur-[120px] -translate-y-1/2"
      >
      </div>
      <div
        class="glow-orb absolute top-1/2 right-1/4 w-[400px] h-[400px] rounded-full bg-warm/10 blur-[100px] -translate-y-1/2"
        style="animation-delay: 3s"
      >
      </div>
    </div>
    <div class="container relative z-10 text-center anim-scale-blur">
      <h2 class="text-h1 text-text-on-dark max-w-3xl mx-auto">
        {t("home.ctaSection.title")}
      </h2>
      <p class="text-body-lg text-text-on-dark/60 mt-6 max-w-xl mx-auto">
        {t("home.ctaSection.subtitle")}
      </p>
      <div class="mt-10">
        <Button
          href={contactHref}
          variant="primary"
          tone="on-dark"
          class="btn-glow group"
        >
          {t("home.ctaSection.cta")}
          <ArrowRight
            class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1"
          />
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initScrollAnimations() {
    if (CSS.supports("animation-timeline: scroll()")) return;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    document
      .querySelectorAll(
        ".anim-scale-blur, .anim-slide-up, .anim-slide-left, .anim-slide-right, .anim-fade, .anim-card-enter",
      )
      .forEach((el) => observer.observe(el));
  }
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>

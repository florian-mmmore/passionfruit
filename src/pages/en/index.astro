---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import FAQs from '~/components/FAQs.astro';
import { useTranslations, getLocalizedPath } from '~/i18n';
import { getTestimonials } from '~/data/testimonials';
import { getFAQs } from '~/data/faqs';

const lang = 'en' as const;
const { t } = useTranslations(lang);
const testimonials = getTestimonials(lang);
const faqItems = getFAQs(lang);
const contactHref = getLocalizedPath('contact', lang);
---

<BaseLayout
  title={t('site.name')}
  description={t('site.description')}
  lang={lang}
  headerVariant="on-dark"
>
  <!-- Hero -->
  <section class="bg-surface-dark text-text-on-dark">
    <div class="container section text-center">
      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6 text-text-on-dark">
        {t('home.hero.headline')}
      </h1>
      <p class="text-xl text-text-on-dark/80 max-w-2xl mx-auto mb-10">
        {t('home.hero.subheadline')}
      </p>
      <Button href={contactHref} variant="primary" tone="on-dark">
        {t('home.hero.cta')}
      </Button>
    </div>
  </section>

  <!-- Features -->
  <section class="container section">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-text-heading mb-3">{t('home.features.title')}</h2>
      <p class="text-muted text-lg max-w-xl mx-auto">{t('home.features.subtitle')}</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      <div class="card flex flex-col gap-3">
        <h3 class="text-lg font-bold text-text-heading">{t('services.webDesign.title')}</h3>
        <p class="text-muted text-sm leading-relaxed">{t('services.webDesign.description')}</p>
      </div>
      <div class="card flex flex-col gap-3">
        <h3 class="text-lg font-bold text-text-heading">{t('services.development.title')}</h3>
        <p class="text-muted text-sm leading-relaxed">{t('services.development.description')}</p>
      </div>
      <div class="card flex flex-col gap-3">
        <h3 class="text-lg font-bold text-text-heading">{t('services.consulting.title')}</h3>
        <p class="text-muted text-sm leading-relaxed">{t('services.consulting.description')}</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-surface-dark/5">
    <div class="container section">
      <h2 class="text-3xl font-bold text-text-heading text-center mb-12">
        {t('home.testimonials.title')}
      </h2>

      <div class="grid gap-6 sm:grid-cols-2">
        {testimonials.map((item) => (
          <blockquote class="card flex flex-col gap-4">
            <p class="text-text leading-relaxed">"{item.quote}"</p>
            <footer class="text-sm">
              <strong class="text-text-heading">{item.author}</strong>
              <span class="text-muted"> — {item.company}</span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="container section">
    <h2 class="text-3xl font-bold text-text-heading text-center mb-12">
      {t('home.faq.title')}
    </h2>
    <div class="max-w-2xl mx-auto">
      <FAQs items={faqItems} />
    </div>
  </section>

  <!-- CTA section -->
  <section class="bg-surface-dark">
    <div class="container section text-center">
      <h2 class="text-3xl font-bold text-text-on-dark mb-4">
        {t('home.ctaSection.title')}
      </h2>
      <p class="text-text-on-dark/80 text-lg mb-10 max-w-xl mx-auto">
        {t('home.ctaSection.subtitle')}
      </p>
      <Button href={contactHref} variant="primary" tone="on-dark">
        {t('home.ctaSection.cta')}
      </Button>
    </div>
  </section>
</BaseLayout>

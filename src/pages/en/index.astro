---
import { Image } from 'astro:assets';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import FAQs from '~/components/FAQs.astro';
import { useTranslations, getLocalizedPath } from '~/i18n';
import { getTestimonials } from '~/data/testimonials';
import { getFAQs } from '~/data/faqs';
import { Palette, Code, Lightbulb, Quote } from '@lucide/astro';
import heroImage from '~/assets/home/hero.png';

const lang = 'en' as const;
const { t } = useTranslations(lang);
const testimonials = getTestimonials(lang);
const faqItems = getFAQs(lang);
const contactHref = getLocalizedPath('contact', lang);
---

<BaseLayout
  title={t('site.name')}
  description={t('site.description')}
  lang={lang}
  headerVariant="on-dark"
>
  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-surface-dark">
    <Image
      src={heroImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-40"
      widths={[640, 1024, 1536]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-surface-dark/80 via-surface-dark/50 to-surface-dark"></div>
    <div class="container relative z-10 py-32 md:py-40 text-center">
      <p class="text-accent font-semibold tracking-wide text-sm uppercase mb-4">
        {t('site.name')}
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6 text-text-on-dark max-w-4xl mx-auto">
        {t('home.hero.headline')}
      </h1>
      <p class="text-lg md:text-xl text-text-on-dark/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        {t('home.hero.subheadline')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={contactHref} variant="primary" tone="on-dark">
          {t('home.hero.cta')}
        </Button>
        <Button href={getLocalizedPath('services', lang)} variant="ghost" tone="on-dark">
          {t('services.title')}
        </Button>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="container py-24 md:py-32">
    <div class="text-center mb-16">
      <p class="text-accent font-semibold tracking-wide text-sm uppercase mb-3">{t('services.title')}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading mb-4">{t('home.features.title')}</h2>
      <p class="text-muted text-lg max-w-xl mx-auto">{t('home.features.subtitle')}</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      <div class="card flex flex-col gap-4 p-8">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center">
          <Palette class="w-6 h-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold text-text-heading">{t('services.webDesign.title')}</h3>
        <p class="text-muted leading-relaxed">{t('services.webDesign.description')}</p>
      </div>
      <div class="card flex flex-col gap-4 p-8">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center">
          <Code class="w-6 h-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold text-text-heading">{t('services.development.title')}</h3>
        <p class="text-muted leading-relaxed">{t('services.development.description')}</p>
      </div>
      <div class="card flex flex-col gap-4 p-8">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center">
          <Lightbulb class="w-6 h-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold text-text-heading">{t('services.consulting.title')}</h3>
        <p class="text-muted leading-relaxed">{t('services.consulting.description')}</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-surface-dark/[0.03]">
    <div class="container py-24 md:py-32">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-text-heading">
          {t('home.testimonials.title')}
        </h2>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 max-w-4xl mx-auto">
        {testimonials.map((item) => (
          <blockquote class="card p-8 flex flex-col gap-6">
            <Quote class="w-8 h-8 text-accent/30" />
            <p class="text-text leading-relaxed text-lg">{item.quote}</p>
            <footer class="mt-auto pt-4 border-t border-border">
              <strong class="text-text-heading">{item.author}</strong>
              <span class="text-muted block text-sm">{item.company}</span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="container py-24 md:py-32">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading">
        {t('home.faq.title')}
      </h2>
    </div>
    <div class="max-w-2xl mx-auto">
      <FAQs items={faqItems} />
    </div>
  </section>

  <!-- CTA section -->
  <section class="relative overflow-hidden bg-surface-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/20 via-transparent to-transparent"></div>
    <div class="container relative z-10 py-24 md:py-32 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-text-on-dark mb-4 max-w-2xl mx-auto">
        {t('home.ctaSection.title')}
      </h2>
      <p class="text-text-on-dark/70 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        {t('home.ctaSection.subtitle')}
      </p>
      <Button href={contactHref} variant="primary" tone="on-dark">
        {t('home.ctaSection.cta')}
      </Button>
    </div>
  </section>
</BaseLayout>

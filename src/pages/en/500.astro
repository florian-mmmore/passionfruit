---
import BaseLayout from "~/layouts/BaseLayout.astro";
import AsymmetricHero from "~/components/sections/AsymmetricHero.astro";
import { useTranslations, type Locale } from "~/i18n";
import heroImage from "~/assets/home/hero.png";

// EN mirror of the root 500. Cloudflare Pages walks up the directory tree
// to find the nearest 500.html, so an EN-route function error serves this.
const lang: Locale = "en";
const { t } = useTranslations(lang);

const homeHref = "/en/";
const title = t("state.500.title");
const description = t("state.500.body");
---

<BaseLayout title={title} description={description} lang={lang} noindex={true}>
  <AsymmetricHero
    eyebrow="500"
    headline={title}
    lede={description}
    cta={{ label: t("state.500.cta"), href: homeHref }}
    image={heroImage}
    imageAlt=""
    imagePosition="right"
    tone="surface"
    padding="lg"
  />
</BaseLayout>

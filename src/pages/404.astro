---
import "~/styles/global.css";
import "~/styles/scroll-animations.css";
import { useTranslations } from "~/i18n";
import Button from "~/components/Button.astro";
import { ArrowLeft } from "@lucide/astro";

const de = useTranslations("de");
const en = useTranslations("en");
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | Greenleaf Digital</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-surface-dark min-h-screen flex flex-col noise">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div
      class="glow-orb absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full bg-accent/15 blur-[120px]"
    >
    </div>
    <div
      class="glow-orb absolute bottom-1/3 right-1/4 w-[400px] h-[400px] rounded-full bg-warm/10 blur-[100px]"
      style="animation-delay: 4s"
    >
    </div>

    <main class="flex-1 flex items-center justify-center relative z-10 px-6">
      <div class="max-w-lg text-center">
        <p
          class="gradient-text font-extrabold hero-stagger"
          style="font-size: clamp(6rem, 15vw, 12rem); line-height: 1; --delay: 100ms"
        >
          404
        </p>

        <div class="mt-8 space-y-10">
          <!-- German -->
          <section lang="de" class="hero-stagger" style="--delay: 300ms">
            <h1 class="text-h2 text-text-on-dark font-bold">
              {de.t("error.notFound")}
            </h1>
            <p class="text-text-on-dark/50 mt-2 leading-relaxed">
              {de.t("error.notFoundDescription")}
            </p>
            <div class="mt-6">
              <Button href="/" variant="secondary" tone="on-dark" class="group">
                <ArrowLeft
                  class="w-4 h-4 mr-2 transition-transform group-hover:-translate-x-1"
                />
                {de.t("error.backHome")}
              </Button>
            </div>
          </section>

          <div class="w-16 h-px bg-white/10 mx-auto"></div>

          <!-- English -->
          <section lang="en" class="hero-stagger" style="--delay: 500ms">
            <h2 class="text-h2 text-text-on-dark font-bold">
              {en.t("error.notFound")}
            </h2>
            <p class="text-text-on-dark/50 mt-2 leading-relaxed">
              {en.t("error.notFoundDescription")}
            </p>
            <div class="mt-6">
              <Button
                href="/en/"
                variant="secondary"
                tone="on-dark"
                class="group"
              >
                <ArrowLeft
                  class="w-4 h-4 mr-2 transition-transform group-hover:-translate-x-1"
                />
                {en.t("error.backHome")}
              </Button>
            </div>
          </section>
        </div>
      </div>
    </main>
  </body>
</html>

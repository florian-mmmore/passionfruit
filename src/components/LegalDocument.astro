---
import type { Locale } from "~/i18n";
import { useTranslations } from "~/i18n";
import { formatDate } from "~/lib/format-date";
import Prose from "~/components/Prose.astro";
import "~/styles/blog-prose.css";

interface Props {
  title: string;
  lang: Locale;
  lastUpdated?: Date;
  class?: string;
}

const { title, lang, lastUpdated, class: className } = Astro.props;
const { t } = useTranslations(lang);
---

<section class:list={["py-20 md:py-28", className]}>
  <div class="container">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-text-heading leading-tight mb-4">
        {title}
      </h1>
      {
        lastUpdated && (
          <p class="text-sm text-muted mb-8">
            {t("legal.lastUpdated")}{" "}
            <time datetime={lastUpdated.toISOString()}>
              {formatDate(lastUpdated, lang)}
            </time>
          </p>
        )
      }
      <article class="blog-prose">
        <Prose measure="wide">
          <slot />
        </Prose>
      </article>
    </div>
  </div>
</section>

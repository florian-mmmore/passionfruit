---
import { RotateCcw } from "@lucide/astro";
import { useTranslations, type Locale } from "~/i18n";

export interface FacetValue {
  /** URL-safe key used in query params, e.g. "ai" or "case-study" */
  key: string;
  /** User-visible label */
  label: string;
  /** Optional item count displayed next to the label */
  count?: number;
}

export interface Facet {
  /** Query param name, e.g. "category" or "tag" */
  key: string;
  /** User-visible group heading */
  label: string;
  /** Available values for this facet */
  values: FacetValue[];
}

interface Props {
  /** Taxonomy groups — each becomes a set of filter chips */
  facets: Facet[];
  /** Current active selections keyed by facet key, e.g. { tag: ["ai", "design"] } */
  selected: Record<string, string[]>;
  lang: Locale;
  /** Base URL to build filter links against — pass Astro.url.pathname */
  baseUrl: string;
  /** Controls idle chip styling: "on-light" (default) or "on-dark" */
  tone?: "on-light" | "on-dark";
  /** Override the "Reset filters" label; falls back to t('filter.reset') */
  resetLabel?: string;
  /** Extra classes on the root element */
  class?: string;
}

const {
  facets,
  selected,
  lang,
  baseUrl,
  tone = "on-light",
  resetLabel,
  class: className = "",
} = Astro.props;

const { t } = useTranslations(lang);

const resolvedResetLabel = resetLabel ?? t("filter.reset");
const allLabel = t("filter.allLabel");

/**
 * Build a URL for toggling a specific facet value.
 * Adds the value if absent; removes it if already selected.
 */
function buildToggleUrl(facetKey: string, valueKey: string): string {
  const params = new URLSearchParams();

  for (const [fk, values] of Object.entries(selected)) {
    const next =
      fk === facetKey
        ? values.includes(valueKey)
          ? values.filter((v) => v !== valueKey)
          : [...values, valueKey]
        : values;
    for (const v of next) {
      params.append(fk, v);
    }
  }

  if (!(facetKey in selected)) {
    params.append(facetKey, valueKey);
  }

  const qs = params.toString();
  return qs ? `${baseUrl}?${qs}` : baseUrl;
}

/** URL that clears all filters — just the base path with no params */
const resetUrl = baseUrl;

const hasActiveFilters = Object.values(selected).some((v) => v.length > 0);

const idleChipClasses =
  tone === "on-dark" ? "chip--idle-dark" : "chip--idle-light";
---

<nav
  class:list={["collection-filter", className]}
  aria-label={t("filter.ariaLabel")}
>
  {
    facets.map((facet) => {
      const activeValues = selected[facet.key] ?? [];

      // Build "All" href — current params minus this facet
      const allParams = new URLSearchParams();
      for (const [fk, values] of Object.entries(selected)) {
        if (fk !== facet.key) {
          for (const v of values) allParams.append(fk, v);
        }
      }
      const allQs = allParams.toString();
      const allHref = allQs ? `${baseUrl}?${allQs}` : baseUrl;
      const isAll = activeValues.length === 0;

      return (
        <div class="flex flex-wrap items-center gap-2 mb-3 last:mb-0">
          <span class="text-xs font-semibold uppercase tracking-wide text-muted mr-1 shrink-0">
            {facet.label}
          </span>

          <a
            href={allHref}
            aria-current={isAll ? "true" : undefined}
            class:list={["chip", isAll ? "chip--active" : idleChipClasses]}
          >
            {allLabel}
          </a>

          {facet.values.map((val) => {
            const isActive = activeValues.includes(val.key);
            return (
              <a
                href={buildToggleUrl(facet.key, val.key)}
                aria-current={isActive ? "true" : undefined}
                class:list={[
                  "chip",
                  isActive ? "chip--active" : idleChipClasses,
                ]}
              >
                {val.label}
                {val.count !== undefined && (
                  <span class="ml-1 opacity-60 text-xs">({val.count})</span>
                )}
              </a>
            );
          })}
        </div>
      );
    })
  }

  {
    hasActiveFilters && (
      <div class="mt-2">
        <a
          href={resetUrl}
          class:list={[
            "inline-flex items-center gap-1.5 text-sm font-medium motion-safe:transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded",
            tone === "on-dark"
              ? "text-white/60 hover:text-white"
              : "text-muted hover:text-accent",
          ]}
          aria-label={resolvedResetLabel}
        >
          <RotateCcw size={14} aria-hidden="true" />
          {resolvedResetLabel}
        </a>
      </div>
    )
  }
</nav>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid transparent;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1;
    text-decoration: none;
    /* 44px min touch target */
    min-height: 2.75rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .chip {
      transition:
        background-color 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
    }
  }

  /* On-light idle */
  .chip--idle-light {
    background-color: var(--color-surface-elevated);
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .chip--idle-light:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* On-dark idle */
  .chip--idle-dark {
    background-color: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.15);
    color: var(--color-text-on-dark);
  }

  .chip--idle-dark:hover {
    border-color: var(--color-accent-glow);
    color: var(--color-accent-glow);
  }

  /* Active state — same regardless of tone */
  .chip--active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .chip--active:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .chip:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

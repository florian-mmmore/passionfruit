---
/**
 * EmptyState — collection or query returned nothing.
 *
 * Always has a CTA. Dead-end empties are a UX failure: the user got here
 * for a reason, and "nothing here" without a way forward is worse than
 * an error. Pair it with an illustration via the `illustration` slot, or
 * fall back to a calm icon.
 */
import { Inbox } from "@lucide/astro";
import Button from "~/components/Button.astro";

interface Props {
  headline: string;
  body: string;
  cta: { label: string; href: string };
  class?: string;
}

const { headline, body, cta, class: className = "" } = Astro.props;
---

<div class:list={["pf-empty-state", className]}>
  <div class="pf-empty-state__illustration" aria-hidden="true">
    <slot name="illustration">
      <Inbox class="pf-empty-state__icon" />
    </slot>
  </div>

  <h3 class="text-h2 pf-empty-state__headline">{headline}</h3>
  <p class="pf-empty-state__body">{body}</p>

  <div class="pf-empty-state__cta">
    <Button href={cta.href} variant="primary" tone="on-light">
      {cta.label}
    </Button>
  </div>
</div>

<style>
  .pf-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding-block: var(--space-section-md);
    padding-inline: var(--space-4);
    max-width: 36rem;
    margin-inline: auto;
  }

  .pf-empty-state__illustration {
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  :global(.pf-empty-state__icon) {
    width: 3rem;
    height: 3rem;
    stroke-width: 1.25;
  }

  .pf-empty-state__headline {
    margin: 0;
    color: var(--color-text-heading);
  }

  .pf-empty-state__body {
    margin: 0;
    color: var(--color-muted);
    max-width: 32rem;
    line-height: var(--leading-body);
  }

  .pf-empty-state__cta {
    margin-top: var(--space-2);
  }
</style>

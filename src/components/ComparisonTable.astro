---
import { Check, X } from "@lucide/astro";
import type { Locale } from "~/i18n";
import { useTranslations } from "~/i18n";

interface Column {
  name: string;
  highlight?: boolean;
}

interface Row {
  feature: string;
  values: (boolean | string)[];
}

interface Props {
  columns: Column[];
  rows: Row[];
  lang?: Locale;
  class?: string;
}

const { columns, rows, lang = "de", class: className } = Astro.props;
const { t } = useTranslations(lang);
---

<div class:list={["w-full", className]}>
  {/* Desktop: grid table — hidden on mobile */}
  <div class="hidden md:block overflow-hidden rounded-xl border border-border">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr>
          <th
            scope="col"
            class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider text-muted bg-surface"
          >
            <span class="sr-only">{t("comparison.feature")}</span>
          </th>
          {
            columns.map((col) => (
              <th
                scope="col"
                class:list={[
                  "px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider",
                  col.highlight
                    ? "bg-accent/5 text-accent ring-1 ring-inset ring-accent/20"
                    : "bg-surface text-muted",
                ]}
              >
                {col.name}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row, rowIdx) => (
            <tr
              class:list={[
                "border-t border-border",
                rowIdx % 2 === 0 ? "bg-surface-elevated" : "bg-surface",
              ]}
            >
              <th
                scope="row"
                class="px-6 py-4 text-left text-sm font-medium text-text-heading"
              >
                {row.feature}
              </th>
              {columns.map((col, colIdx) => {
                const value = row.values[colIdx];
                return (
                  <td
                    class:list={[
                      "px-6 py-4 text-center align-middle",
                      col.highlight
                        ? "bg-accent/5 ring-1 ring-inset ring-accent/20"
                        : "",
                    ]}
                  >
                    {typeof value === "boolean" ? (
                      value ? (
                        <span
                          class="inline-flex items-center justify-center"
                          aria-label={t("comparison.yes")}
                        >
                          <Check
                            class="w-5 h-5 text-accent"
                            aria-hidden="true"
                          />
                        </span>
                      ) : (
                        <span
                          class="inline-flex items-center justify-center"
                          aria-label={t("comparison.no")}
                        >
                          <X class="w-5 h-5 text-muted" aria-hidden="true" />
                        </span>
                      )
                    ) : (
                      <span class="text-sm text-text">{value}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {/* Mobile: per-column cards stacked */}
  <div class="md:hidden space-y-6">
    {
      columns.map((col, colIdx) => (
        <div
          class:list={[
            "rounded-xl border overflow-hidden",
            col.highlight
              ? "border-accent/30 ring-1 ring-accent/20"
              : "border-border",
          ]}
        >
          <div
            class:list={[
              "px-4 py-3 text-sm font-semibold uppercase tracking-wider text-center",
              col.highlight
                ? "bg-accent/5 text-accent"
                : "bg-surface text-muted",
            ]}
          >
            {col.name}
          </div>
          <ul role="list" class="divide-y divide-border">
            {rows.map((row) => {
              const value = row.values[colIdx];
              return (
                <li class="flex items-center justify-between gap-4 px-4 py-3 bg-surface-elevated">
                  <span class="text-sm font-medium text-text-heading">
                    {row.feature}
                  </span>
                  {typeof value === "boolean" ? (
                    value ? (
                      <span
                        class="inline-flex shrink-0"
                        aria-label={t("comparison.yes")}
                      >
                        <Check class="w-5 h-5 text-accent" aria-hidden="true" />
                      </span>
                    ) : (
                      <span
                        class="inline-flex shrink-0"
                        aria-label={t("comparison.no")}
                      >
                        <X class="w-5 h-5 text-muted" aria-hidden="true" />
                      </span>
                    )
                  ) : (
                    <span class="text-sm text-muted text-right">{value}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</div>

---
import { getCollection, render } from 'astro:content';
import type { Locale } from '~/i18n';
import { useTranslations } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getAlternateCollectionSlug } from '~/lib/page-registry';

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allPages = await getCollection('pages');
const entry = allPages.find(
  (p) => p.id.startsWith(`${lang}/`) && p.data.translationKey === 'privacy',
);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
const alternateSlug = await getAlternateCollectionSlug(lang, 'pages', 'privacy');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
  currentSlug={currentSlug}
  alternateSlug={alternateSlug}
>
  <section class="py-20 md:py-28">
    <div class="container">
      <article class="blog-prose max-w-3xl mx-auto">
        <h1>{entry.data.title}</h1>
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

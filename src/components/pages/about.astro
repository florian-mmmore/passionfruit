---
import { getCollection } from 'astro:content';
import type { Locale } from '~/i18n';
import { useTranslations } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageContent from '~/components/PageContent.astro';
import { getAlternateCollectionSlug } from '~/lib/page-registry';

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allPages = await getCollection('pages');
const entry = allPages.find(
  (p) => p.id.startsWith(`${lang}/`) && (p.data as { translationKey: string }).translationKey === 'about',
);

if (!entry) {
  return Astro.redirect('/404');
}

const alternateSlug = await getAlternateCollectionSlug(lang, 'pages', 'about');
---

<BaseLayout
  title={t('about.title')}
  description={t('about.description')}
  lang={lang}
  currentSlug={currentSlug}
  alternateSlug={alternateSlug}
>
  <PageContent entry={entry} lang={lang} />
</BaseLayout>

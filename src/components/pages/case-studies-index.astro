---
import { getCollection } from "astro:content";
import { useTranslations, type Locale } from "~/i18n";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CaseStudyCard from "~/components/CaseStudyCard.astro";
import CaseStudiesFilter from "~/components/CaseStudiesFilter.astro";

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const selectedCategories = Astro.url.searchParams.getAll("category");
const selectedTags = Astro.url.searchParams.getAll("tag");
const selected: Record<string, string[]> = {
  category: selectedCategories,
  tag: selectedTags,
};

const allEntries = await getCollection("caseStudies");
let entries = allEntries
  .filter((e) => e.id.startsWith(`${lang}/`))
  .sort((a, b) => {
    const da = a.data.publishedAt ? a.data.publishedAt.getTime() : 0;
    const db = b.data.publishedAt ? b.data.publishedAt.getTime() : 0;
    if (db !== da) return db - da;
    return a.id.localeCompare(b.id);
  });

if (selectedCategories.length > 0) {
  entries = entries.filter((e) => selectedCategories.includes(e.data.category));
}
if (selectedTags.length > 0) {
  entries = entries.filter((e) =>
    e.data.tags.some((tag) => selectedTags.includes(tag)),
  );
}
---

<BaseLayout
  title={t("caseStudies.title")}
  description={t("caseStudies.description")}
  lang={lang}
  currentSlug={currentSlug}
  headerVariant="on-dark"
>
  <!-- Hero -->
  <section class="bg-surface-dark noise relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div
      class="glow-orb absolute top-1/2 left-0 w-[400px] h-[400px] rounded-full bg-accent/15 blur-[120px] -translate-y-1/2 -translate-x-1/3"
    >
    </div>
    <div class="container relative z-10 pt-48 pb-20 md:pt-56 md:pb-28">
      <p class="eyebrow hero-stagger" style="--delay: 100ms">
        {t("site.name")}
      </p>
      <h1
        class="text-h1 text-text-on-dark mt-4 max-w-2xl hero-stagger"
        style="--delay: 200ms"
      >
        {t("caseStudies.title")}
      </h1>
      <p
        class="text-body-lg text-text-on-dark/60 mt-4 max-w-lg hero-stagger"
        style="--delay: 300ms"
      >
        {t("caseStudies.description")}
      </p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="py-20 md:py-28">
    <div class="container">
      <CaseStudiesFilter
        {lang}
        baseUrl={Astro.url.pathname}
        {selected}
        class="mb-12"
      />

      {
        entries.length === 0 ? (
          <p class="text-muted text-center py-16">
            {t("caseStudies.noResults")}
          </p>
        ) : (
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {entries.map((entry, i) => (
              <div class="anim-card-enter" style={`--delay: ${i * 100}ms`}>
                <CaseStudyCard {entry} {lang} />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  function initScrollAnimations() {
    if (CSS.supports("animation-timeline: scroll()")) return;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries)
          if (e.isIntersecting) {
            e.target.classList.add("in-view");
            observer.unobserve(e.target);
          }
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    document
      .querySelectorAll(".anim-card-enter, .anim-slide-up, .anim-fade")
      .forEach((el) => observer.observe(el));
  }
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>

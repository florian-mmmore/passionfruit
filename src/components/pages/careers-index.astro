---
import { getCollection } from "astro:content";
import type { Locale } from "~/i18n";
import { useTranslations } from "~/i18n";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CareerCard from "~/components/CareerCard.astro";

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allJobs = await getCollection("careers");
const jobs = allJobs
  .filter((j) => j.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.postedAt.getTime() - a.data.postedAt.getTime());
---

<BaseLayout
  title={t("careers.title")}
  description={t("careers.description")}
  lang={lang}
  currentSlug={currentSlug}
  headerVariant="on-dark"
>
  <!-- Hero -->
  <section class="bg-surface-dark noise relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div
      class="glow-orb absolute top-1/2 left-0 w-[400px] h-[400px] rounded-full bg-accent/15 blur-[120px] -translate-y-1/2 -translate-x-1/3"
    >
    </div>
    <div class="container relative z-10 pt-48 pb-20 md:pt-56 md:pb-28">
      <p class="eyebrow hero-stagger" style="--delay: 100ms">
        {t("site.name")}
      </p>
      <h1
        class="text-h1 text-text-on-dark mt-4 max-w-2xl hero-stagger"
        style="--delay: 200ms"
      >
        {t("careers.title")}
      </h1>
      <p
        class="text-body-lg text-text-on-dark/60 mt-4 max-w-lg hero-stagger"
        style="--delay: 300ms"
      >
        {t("careers.description")}
      </p>
    </div>
  </section>

  <!-- Job listings -->
  <section class="py-20 md:py-28 bg-surface-dark">
    <div class="container">
      {
        jobs.length === 0 ? (
          <p class="text-text-on-dark/50 text-center py-16">
            {t("careers.noOpenings")}
          </p>
        ) : (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {jobs.map((job, i) => (
              <div class="anim-card-enter" style={`--delay: ${i * 100}ms`}>
                <CareerCard entry={job} lang={lang} />
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  function initScrollAnimations() {
    if (CSS.supports("animation-timeline: scroll()")) return;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries)
          if (e.isIntersecting) {
            e.target.classList.add("in-view");
            observer.unobserve(e.target);
          }
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    document
      .querySelectorAll(".anim-card-enter, .anim-slide-up, .anim-fade")
      .forEach((el) => observer.observe(el));
  }
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>

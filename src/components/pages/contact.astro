---
import { getCollection, render } from 'astro:content';
import type { Locale } from '~/i18n';
import { useTranslations } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import { getAlternateCollectionSlug } from '~/lib/page-registry';
import { Mail, Phone, MapPin, Send } from '@lucide/astro';

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allPages = await getCollection('pages');
const entry = allPages.find(
  (p) => p.id.startsWith(`${lang}/`) && p.data.translationKey === 'contact',
);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
const alternateSlug = await getAlternateCollectionSlug(lang, 'pages', 'contact');

const inputClasses = 'w-full px-4 py-3 rounded-[var(--radius-md)] border border-border bg-surface-elevated text-text placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all duration-[var(--transition-fast)]';
---

<BaseLayout
  title={t('contact.title')}
  description={t('contact.description')}
  lang={lang}
  currentSlug={currentSlug}
  alternateSlug={alternateSlug}
  headerVariant="on-dark"
>
  <section class="bg-surface-dark noise relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div class="glow-orb absolute top-1/2 right-0 w-[400px] h-[400px] rounded-full bg-accent/15 blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
    <div class="container relative z-10 pt-32 pb-20 md:pt-40 md:pb-28">
      <p class="eyebrow hero-stagger" style="--delay: 100ms">{t('site.name')}</p>
      <h1 class="text-h1 text-text-on-dark mt-4 max-w-2xl hero-stagger" style="--delay: 200ms">{entry.data.title}</h1>
      <p class="text-body-lg text-text-on-dark/60 mt-4 max-w-lg hero-stagger" style="--delay: 300ms">{entry.data.description}</p>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="container">
      <div class="grid lg:grid-cols-5 gap-16 max-w-5xl mx-auto">
        <!-- Contact info -->
        <div class="lg:col-span-2 anim-slide-up">
          <article class="blog-prose mb-8">
            <Content />
          </article>
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-3 text-muted">
              <Mail class="w-5 h-5 text-accent flex-shrink-0" />
              <span>hello@example.com</span>
            </div>
            <div class="flex items-center gap-3 text-muted">
              <Phone class="w-5 h-5 text-accent flex-shrink-0" />
              <span>+49 123 456 789</span>
            </div>
            <div class="flex items-center gap-3 text-muted">
              <MapPin class="w-5 h-5 text-accent flex-shrink-0" />
              <span>Musterstraße 1, 12345 Musterstadt</span>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-3 anim-slide-up" style="--delay: 150ms">
          <form action="#" method="POST" class="card flex flex-col gap-5 p-8">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-sm font-semibold text-text-heading">
                {t('contact.form.name')}
              </label>
              <input id="name" name="name" type="text" autocomplete="name" required class={inputClasses} />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-sm font-semibold text-text-heading">
                {t('contact.form.email')}
              </label>
              <input id="email" name="email" type="email" autocomplete="email" required class={inputClasses} />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="message" class="text-sm font-semibold text-text-heading">
                {t('contact.form.message')}
              </label>
              <textarea id="message" name="message" rows={6} required class={`${inputClasses} resize-y`}></textarea>
            </div>

            <Button type="submit" variant="primary" class="btn-glow group self-start">
              {t('contact.form.send')}
              <Send class="w-4 h-4 ml-2" />
            </Button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initScrollAnimations() {
    if (CSS.supports('animation-timeline: scroll()')) return;
    const observer = new IntersectionObserver(
      (entries) => { for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in-view'); observer.unobserve(e.target); } },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('.anim-card-enter, .anim-slide-up, .anim-fade').forEach((el) => observer.observe(el));
  }
  initScrollAnimations();
  document.addEventListener('astro:after-swap', initScrollAnimations);
</script>

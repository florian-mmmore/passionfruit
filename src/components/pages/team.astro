---
import { getCollection } from 'astro:content';
import type { Locale } from '~/i18n';
import { useTranslations } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import TeamCard from '~/components/TeamCard.astro';

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allMembers = await getCollection('team');
const members = allMembers
  .filter((m) => m.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder);
---

<BaseLayout
  title={t('team.title')}
  description={t('team.description')}
  lang={lang}
  currentSlug={currentSlug}
>
  <section class="container section">
    <h1 class="text-4xl font-bold text-text-heading mb-4">{t('team.title')}</h1>
    <p class="text-muted text-lg mb-12">{t('team.description')}</p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {members.map((member) => (
        <TeamCard entry={member} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>

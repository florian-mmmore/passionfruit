---
import { getCollection, render } from 'astro:content';
import type { Locale } from '~/i18n';
import { useTranslations, getLocalizedPath } from '~/i18n';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/Button.astro';
import { getAlternateCollectionSlug } from '~/lib/page-registry';
import { Palette, Code, Lightbulb, ArrowRight } from '@lucide/astro';

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const { t } = useTranslations(lang);

const allPages = await getCollection('pages');
const entry = allPages.find(
  (p) => p.id.startsWith(`${lang}/`) && p.data.translationKey === 'services',
);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
const alternateSlug = await getAlternateCollectionSlug(lang, 'pages', 'services');
const contactHref = getLocalizedPath(lang === 'de' ? 'kontakt' : 'contact', lang);

const services = [
  { icon: Palette, titleKey: 'services.webDesign.title', descKey: 'services.webDesign.description' },
  { icon: Code, titleKey: 'services.development.title', descKey: 'services.development.description' },
  { icon: Lightbulb, titleKey: 'services.consulting.title', descKey: 'services.consulting.description' },
];
---

<BaseLayout
  title={t('services.title')}
  description={t('services.description')}
  lang={lang}
  currentSlug={currentSlug}
  alternateSlug={alternateSlug}
  headerVariant="on-dark"
>
  <section class="bg-surface-dark noise relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div class="glow-orb absolute top-1/2 left-0 w-[400px] h-[400px] rounded-full bg-accent/15 blur-[120px] -translate-y-1/2 -translate-x-1/3"></div>
    <div class="container relative z-10 pt-32 pb-20 md:pt-40 md:pb-28">
      <p class="eyebrow hero-stagger" style="--delay: 100ms">{t('site.name')}</p>
      <h1 class="text-h1 text-text-on-dark mt-4 max-w-2xl hero-stagger" style="--delay: 200ms">{entry.data.title}</h1>
      <p class="text-body-lg text-text-on-dark/60 mt-4 max-w-lg hero-stagger" style="--delay: 300ms">{entry.data.description}</p>
    </div>
  </section>

  <!-- Service cards -->
  <section class="py-20 md:py-28">
    <div class="container">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 mb-20">
        {services.map((svc, i) => (
          <div class="card anim-card-enter" style={`--delay: ${i * 100}ms`}>
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-6">
              <svc.icon class="w-6 h-6 text-accent" />
            </div>
            <h2 class="text-h3 text-text-heading">{t(svc.titleKey)}</h2>
            <p class="text-muted mt-3 leading-relaxed">{t(svc.descKey)}</p>
          </div>
        ))}
      </div>

      <article class="blog-prose max-w-3xl mx-auto anim-slide-up">
        <Content />
      </article>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface-dark noise relative overflow-hidden">
    <div class="glow-orb absolute top-1/2 left-1/3 w-[400px] h-[400px] rounded-full bg-accent/10 blur-[120px] -translate-y-1/2"></div>
    <div class="container relative z-10 py-20 md:py-28 text-center anim-scale-blur">
      <h2 class="text-h2 text-text-on-dark max-w-2xl mx-auto">{t('home.ctaSection.title')}</h2>
      <p class="text-body-lg text-text-on-dark/60 mt-4 max-w-lg mx-auto">{t('home.ctaSection.subtitle')}</p>
      <div class="mt-10">
        <Button href={contactHref} variant="primary" tone="on-dark" class="btn-glow group">
          {t('cta.contact')}
          <ArrowRight class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" />
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initScrollAnimations() {
    if (CSS.supports('animation-timeline: scroll()')) return;
    const observer = new IntersectionObserver(
      (entries) => { for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in-view'); observer.unobserve(e.target); } },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('.anim-card-enter, .anim-slide-up, .anim-fade, .anim-scale-blur').forEach((el) => observer.observe(el));
  }
  initScrollAnimations();
  document.addEventListener('astro:after-swap', initScrollAnimations);
</script>

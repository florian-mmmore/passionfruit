---
import { getCollection, render } from "astro:content";
import type { Locale } from "~/i18n";
import BaseLayout from "~/layouts/BaseLayout.astro";
import LegalDocument from "~/components/LegalDocument.astro";
import { getAlternateCollectionSlug } from "~/lib/page-registry";

interface Props {
  lang: Locale;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;

const allPages = await getCollection("pages");
const entry = allPages.find(
  (p) => p.id.startsWith(`${lang}/`) && p.data.translationKey === "imprint",
);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
const alternateSlug = await getAlternateCollectionSlug(
  lang,
  "pages",
  "imprint",
);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
  currentSlug={currentSlug}
  alternateSlug={alternateSlug}
>
  <LegalDocument title={entry.data.title} lang={lang}>
    <Content />
  </LegalDocument>
</BaseLayout>

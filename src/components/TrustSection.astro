---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface LogoItem {
  src: ImageMetadata;
  alt: string;
  href?: string;
}

interface Props {
  eyebrow?: string;
  logos: LogoItem[];
  class?: string;
}

const { eyebrow, logos, class: className } = Astro.props;
---

<section class:list={["py-16 border-y border-border", className]}>
  <div class="container">
    <div class="max-w-5xl mx-auto">
      {
        eyebrow && (
          <p class="eyebrow text-center text-muted mb-10 anim-fade">
            {eyebrow}
          </p>
        )
      }

      <ul
        class="flex flex-wrap items-center justify-center gap-x-10 gap-y-8"
        role="list"
        aria-label={eyebrow}
      >
        {
          logos.map((logo) => (
            <li class="anim-fade">
              {logo.href ? (
                <a
                  href={logo.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-sm"
                  aria-label={logo.alt}
                >
                  <Image
                    src={logo.src}
                    alt=""
                    height={40}
                    class="h-10 w-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              ) : (
                <Image
                  src={logo.src}
                  alt={logo.alt}
                  height={40}
                  class="h-10 w-auto object-contain opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                  loading="lazy"
                  decoding="async"
                />
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

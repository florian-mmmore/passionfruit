---
import { getCollection } from "astro:content";
import CollectionFilter from "~/components/CollectionFilter.astro";
import type { Facet } from "~/components/CollectionFilter.astro";
import { useTranslations, type Locale } from "~/i18n";

interface Props {
  lang: Locale;
  baseUrl: string;
  selected: Record<string, string[]>;
  tone?: "on-light" | "on-dark";
  class?: string;
}

const {
  lang,
  baseUrl,
  selected,
  tone = "on-light",
  class: className = "",
} = Astro.props;
const { t } = useTranslations(lang);

const entries = await getCollection("caseStudies", (e) =>
  e.id.startsWith(`${lang}/`),
);

// Build category counts
const categoryCounts = new Map<string, number>();
for (const entry of entries) {
  const cat = entry.data.category;
  categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1);
}

// Build tag counts
const tagCounts = new Map<string, number>();
for (const entry of entries) {
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const facets: Facet[] = [];

if (categoryCounts.size > 1) {
  facets.push({
    key: "category",
    label: t("caseStudies.filterCategory"),
    values: [...categoryCounts.entries()].map(([key, count]) => ({
      key,
      label: key,
      count,
    })),
  });
}

if (tagCounts.size > 0) {
  facets.push({
    key: "tag",
    label: t("caseStudies.filterTag"),
    values: [...tagCounts.entries()]
      .sort((a, b) => b[1] - a[1])
      .map(([key, count]) => ({ key, label: key, count })),
  });
}
---

{
  facets.length > 0 && (
    <CollectionFilter
      {facets}
      {selected}
      {lang}
      {baseUrl}
      {tone}
      class={className}
    />
  )
}

---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Image } from "astro:assets";
import type { Locale } from "~/i18n";
import { getLocalizedPath, useTranslations } from "~/i18n";
import { formatDate } from "~/lib/format-date";
import { findPageByKey } from "~/lib/page-registry";
import Badge from "~/components/Badge.astro";
import Prose from "~/components/Prose.astro";
import { ArrowLeft } from "@lucide/astro";
import "~/styles/blog-prose.css";

interface Props {
  entry: CollectionEntry<"blog">;
  lang: Locale;
}

const { entry, lang } = Astro.props;
const { t } = useTranslations(lang);
const { Content } = await render(entry);

const parentSlug = findPageByKey("blog-index")?.slug[lang] ?? "blog";
const backHref = getLocalizedPath(parentSlug, lang);
const formattedDate = formatDate(entry.data.publishedAt, lang);
---

<!-- Hero -->
<section class="bg-surface-dark noise relative overflow-hidden">
  <div class="absolute inset-0 bg-grid opacity-20"></div>
  {
    entry.data.heroImage && (
      <Image
        src={entry.data.heroImage}
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-15"
        widths={[640, 1024, 1536]}
        sizes="100vw"
        loading="eager"
      />
    )
  }
  <div
    class="absolute inset-0 bg-gradient-to-b from-surface-dark/60 via-surface-dark/80 to-surface-dark"
  >
  </div>

  <div class="container relative z-10 pt-44 pb-20 md:pt-52 md:pb-28">
    <a
      href={backHref}
      class="inline-flex items-center gap-2 text-sm text-text-on-dark/50 hover:text-text-on-dark transition-colors mb-8 hero-stagger"
      style="--delay: 100ms"
    >
      <ArrowLeft class="w-4 h-4" />
      {t("cta.backToBlog")}
    </a>

    {
      entry.data.tags.length > 0 && (
        <div
          class="flex flex-wrap gap-2 mb-4 hero-stagger"
          style="--delay: 200ms"
        >
          {entry.data.tags.map((tag) => (
            <Badge tone="on-dark">{tag}</Badge>
          ))}
        </div>
      )
    }

    <h1
      class="text-h1 text-text-on-dark max-w-3xl hero-stagger"
      style="--delay: 300ms"
    >
      {entry.data.title}
    </h1>

    <div
      class="flex flex-wrap gap-4 mt-6 text-sm text-text-on-dark/50 hero-stagger"
      style="--delay: 400ms"
    >
      <time datetime={entry.data.publishedAt.toISOString()}>
        {t("blog.publishedAt", { date: formattedDate })}
      </time>
      <span>{t("blog.author", { name: entry.data.author })}</span>
    </div>
  </div>
</section>

<!-- Content -->
<section class="py-16 md:py-24">
  <div class="container">
    <article class="blog-prose max-w-3xl mx-auto">
      <Prose dropCap>
        <Content />
      </Prose>
    </article>

    <div class="max-w-3xl mx-auto mt-16 pt-8 border-t border-border">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm text-muted hover:text-accent transition-colors"
      >
        <ArrowLeft class="w-4 h-4" />
        {t("cta.backToBlog")}
      </a>
    </div>
  </div>
</section>

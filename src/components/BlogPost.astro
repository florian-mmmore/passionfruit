---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import type { Locale } from '~/i18n';
import { getLocalizedPath, useTranslations } from '~/i18n';
import { formatDate } from '~/lib/format-date';
import { findPageByKey } from '~/lib/page-registry';
import '~/styles/blog-prose.css';

interface Props {
	entry: CollectionEntry<'blog'>;
	lang: Locale;
}

const { entry, lang } = Astro.props;

const { t } = useTranslations(lang);
const { Content } = await render(entry);

const parentSlug = findPageByKey('blog-index')?.slug[lang] ?? 'blog';
const backHref = getLocalizedPath(parentSlug, lang);
const formattedDate = formatDate(entry.data.publishedAt, lang);
---

<div class="container section">
	<a
		href={backHref}
		class="inline-flex items-center gap-2 text-sm text-muted hover:text-accent transition-colors duration-[var(--transition-fast)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm mb-8"
	>
		&larr; {t('cta.backToBlog')}
	</a>

	<div class="max-w-3xl mx-auto">
		{entry.data.heroImage && (
			<Image
				src={entry.data.heroImage}
				alt={entry.data.title}
				class="w-full h-72 object-cover rounded-[var(--radius-lg)] mb-8"
				width={900}
				height={450}
			/>
		)}

		<header class="mb-8">
			<h1 class="text-4xl font-bold text-text-heading leading-tight mb-4">
				{entry.data.title}
			</h1>
			<div class="flex flex-wrap gap-4 text-sm text-muted">
				<time datetime={entry.data.publishedAt.toISOString()}>
					{t('blog.publishedAt', { date: formattedDate })}
				</time>
				<span>{t('blog.author', { name: entry.data.author })}</span>
			</div>
		</header>

		<article class="blog-prose">
			<Content />
		</article>
	</div>
</div>

---
import type { CollectionEntry } from "astro:content";
import { MapPin, Briefcase, ArrowRight } from "@lucide/astro";
import type { Locale } from "~/i18n";
import { useTranslations, getLocalizedPath } from "~/i18n";
import { findPageByKey } from "~/lib/page-registry";
import Badge from "~/components/Badge.astro";

interface Props {
  entry: CollectionEntry<"careers">;
  lang: Locale;
}

const { entry, lang } = Astro.props;
const { t } = useTranslations(lang);

const employmentTypeLabel = t(
  `careers.employmentType.${entry.data.employmentType}`,
);

const careersPage = findPageByKey("careers-index");
const careersIndexSlug =
  careersPage?.slug[lang] ?? (lang === "de" ? "karriere" : "careers");
const entrySlug = entry.id.replace(/^[a-z]{2}\//, "");
const href = getLocalizedPath(`${careersIndexSlug}/${entrySlug}`, lang);
---

<a href={href} class="career-card group block">
  <div class="flex items-start justify-between gap-4 mb-5">
    <Badge tone="on-dark">{employmentTypeLabel}</Badge>
    <span class="career-card-arrow" aria-hidden="true">
      <ArrowRight class="w-4 h-4" />
    </span>
  </div>

  <h3
    class="text-h3 text-text-on-dark leading-tight mb-3 group-hover:text-accent transition-colors duration-200"
  >
    {entry.data.title}
  </h3>

  <p class="text-text-on-dark/60 line-clamp-2 mb-6 text-sm leading-relaxed">
    {entry.data.summary}
  </p>

  <div class="flex items-center gap-4 text-sm text-text-on-dark/50">
    <span class="flex items-center gap-1.5">
      <MapPin class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
      {entry.data.location}
    </span>
    {
      entry.data.department && (
        <span class="flex items-center gap-1.5">
          <Briefcase class="w-3.5 h-3.5 shrink-0" aria-hidden="true" />
          {entry.data.department}
        </span>
      )
    }
  </div>
</a>

<style>
  .career-card {
    position: relative;
    padding: 1.75rem;
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-text-on-dark) 3%, transparent);
    border: 1px solid
      color-mix(in srgb, var(--color-text-on-dark) 10%, transparent);
    transition: border-color 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .career-card:hover {
    border-color: var(--color-accent);
  }

  .career-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .career-card-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    min-width: 2rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-text-on-dark) 5%, transparent);
    color: color-mix(in srgb, var(--color-text-on-dark) 30%, transparent);
    transition: all 200ms cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
  }

  .career-card:hover .career-card-arrow {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    transform: translateX(2px);
  }
</style>

---
interface Props {
  variant?: "default" | "status";
  tone?: "on-light" | "on-dark";
}

const { variant = "default", tone = "on-light" } = Astro.props;

const baseClasses =
  "inline-flex items-center px-3 py-1 text-sm font-medium rounded-full";

const onLight: Record<string, string> = {
  default: "bg-accent/10 text-accent",
  status: "bg-green-100 text-green-800",
};

const onDark: Record<string, string> = {
  default: "bg-white/10 text-text-on-dark",
  status: "bg-green-900/30 text-green-400",
};

const variantClasses = tone === "on-dark" ? onDark : onLight;
const classes = [baseClasses, variantClasses[variant]].join(" ");
---

<span class={classes}>
  <slot />
</span>

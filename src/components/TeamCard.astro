---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { Locale } from '~/i18n';
import Badge from '~/components/Badge.astro';
import { ExternalLink } from '@lucide/astro';

interface Props {
	entry: CollectionEntry<'team'>;
	lang: Locale;
}

const { entry } = Astro.props;
const { name, role, photo, specializations, socials } = entry.data;
---

<div class="card flex flex-col gap-4">
	<div class="flex items-center gap-4">
		{photo ? (
			<Image
				src={photo}
				alt={name}
				class="w-16 h-16 rounded-full object-cover shrink-0"
				width={64}
				height={64}
			/>
		) : (
			<div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center shrink-0" aria-hidden="true">
				<span class="text-accent text-xl font-bold">{name.charAt(0)}</span>
			</div>
		)}

		<div>
			<h3 class="text-lg font-bold text-text-heading">{name}</h3>
			<p class="text-sm text-muted">{role}</p>
		</div>
	</div>

	{specializations.length > 0 && (
		<div class="flex flex-wrap gap-2">
			{specializations.map((spec) => (
				<Badge>{spec}</Badge>
			))}
		</div>
	)}

	{(socials.linkedin || socials.github || socials.website) && (
		<div class="flex gap-3 pt-1">
			{socials.linkedin && (
				<a
					href={socials.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-1.5 text-xs text-muted hover:text-accent transition-colors duration-[var(--transition-fast)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm min-h-[44px]"
					aria-label={`${name} on LinkedIn`}
				>
					<ExternalLink size={14} aria-hidden="true" />
					LinkedIn
				</a>
			)}
			{socials.github && (
				<a
					href={socials.github}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-1.5 text-xs text-muted hover:text-accent transition-colors duration-[var(--transition-fast)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm min-h-[44px]"
					aria-label={`${name} on GitHub`}
				>
					<ExternalLink size={14} aria-hidden="true" />
					GitHub
				</a>
			)}
			{socials.website && (
				<a
					href={socials.website}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-1.5 text-xs text-muted hover:text-accent transition-colors duration-[var(--transition-fast)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm min-h-[44px]"
					aria-label={`${name}'s website`}
				>
					<ExternalLink size={14} aria-hidden="true" />
					Website
				</a>
			)}
		</div>
	)}
</div>

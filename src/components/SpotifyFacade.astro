---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Play } from "@lucide/astro";
import { useTranslations, type Locale } from "~/i18n";

type SpotifyKind = "episode" | "track" | "show" | "playlist" | "album";

interface Props {
  episodeId: string;
  title: string;
  cover: ImageMetadata;
  coverAlt: string;
  kind?: SpotifyKind;
  platformLabel?: string;
  lang?: Locale;
  class?: string;
}

const {
  episodeId,
  title,
  cover,
  coverAlt,
  kind = "episode",
  platformLabel = "Spotify",
  lang = "de",
  class: className = "",
} = Astro.props;
const { t } = useTranslations(lang);
const ariaLabel = t("podcast.play", { title });
---

<div
  class:list={[
    "spotify-facade group relative block w-full overflow-hidden rounded-[var(--radius-card)]",
    className,
  ]}
  data-spotify-facade
  data-episode-id={episodeId}
  data-kind={kind}
  data-title={title}
>
  <button
    type="button"
    class="relative flex w-full cursor-pointer appearance-none items-center gap-4 border-0 bg-[var(--color-surface-dark)] p-3 text-left text-[var(--color-text-on-dark)] transition-colors hover:bg-[var(--color-surface-dark-elevated)] sm:p-4"
    aria-label={ariaLabel}
    data-spotify-play
  >
    <span class="spotify-cover" aria-hidden="true">
      <Image
        src={cover}
        alt=""
        widths={[120, 200, 300]}
        sizes="(max-width: 640px) 88px, 112px"
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </span>
    <span class="flex min-w-0 flex-1 flex-col gap-1">
      <span class="font-heading text-xs text-[var(--color-accent)]">
        {platformLabel}
      </span>
      <span
        class="line-clamp-3 text-sm leading-snug font-medium text-[var(--color-text-on-dark)] sm:text-base"
      >
        {title}
      </span>
    </span>
    <span
      class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-white/10 text-[var(--color-text-on-dark)] transition-colors group-hover:bg-white/20"
      aria-hidden="true"
    >
      <Play size={18} fill="currentColor" />
    </span>
    <span class="sr-only">{coverAlt}</span>
  </button>
</div>

<script>
  const facades = document.querySelectorAll<HTMLElement>(
    "[data-spotify-facade]",
  );
  facades.forEach((root) => {
    const btn = root.querySelector<HTMLButtonElement>("[data-spotify-play]");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const episodeId = root.getAttribute("data-episode-id");
      if (!episodeId) return;
      const kind = root.getAttribute("data-kind") ?? "episode";
      const title = root.getAttribute("data-title") ?? "";
      const iframe = document.createElement("iframe");
      iframe.src = `https://open.spotify.com/embed/${kind}/${episodeId}?utm_source=generator&theme=0`;
      iframe.title = title;
      iframe.width = "100%";
      iframe.height = "232";
      iframe.loading = "lazy";
      iframe.allow =
        "autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture";
      iframe.style.border = "0";
      iframe.className = "block w-full";
      root.replaceChildren(iframe);
    });
  });
</script>

<style>
  .spotify-cover {
    flex: none;
    display: block;
    width: 88px;
    height: 88px;
    overflow: hidden;
    border-radius: 8px;
  }

  @media (min-width: 640px) {
    .spotify-cover {
      width: 112px;
      height: 112px;
    }
  }
</style>

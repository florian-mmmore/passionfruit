---
import { Image } from "astro:assets";
import { type CollectionEntry } from "astro:content";
import { ArrowRight, Play } from "@lucide/astro";
import { useTranslations, getLocalizedPath, type Locale } from "~/i18n";
import { findPageByKey } from "~/lib/page-registry";
import Badge from "~/components/Badge.astro";

interface Props {
  entry: CollectionEntry<"caseStudies">;
  lang: Locale;
}

const { entry, lang } = Astro.props;
const { t } = useTranslations(lang);

const entrySlug = entry.id.slice(entry.id.indexOf("/") + 1);
const parentSlug =
  findPageByKey("case-studies-index")?.slug[lang] ??
  (lang === "de" ? "referenzen" : "case-studies");
const href = getLocalizedPath(`${parentSlug}/${entrySlug}`, lang);

const cardLinkLabel = `${entry.data.personName}, ${entry.data.clientName} – ${t("caseStudies.readMore")}`;
---

<article class="case-study-card group">
  <a href={href} class="card-link" aria-label={cardLinkLabel}></a>

  <div
    class:list={[
      "thumbnail",
      entry.data.portraitFit === "contain" && "thumbnail--contain",
    ]}
  >
    <Image
      src={entry.data.portraitImage}
      alt={`${entry.data.personName} | ${entry.data.clientName}`}
      widths={[400, 640, 819]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      class="thumbnail-img"
      loading="lazy"
    />
    {
      entry.data.videoId && (
        <span class="video-badge" aria-label={t("caseStudies.videoAvailable")}>
          <Play class="w-4 h-4" aria-hidden="true" />
        </span>
      )
    }
  </div>

  <div class="content">
    <span class="category">{entry.data.category}</span>

    <blockquote class="quote">
      {t("caseStudies.quoteOpen")}{entry.data.quote}{
        t("caseStudies.quoteClose")
      }
    </blockquote>

    <div class="details">
      <strong class="name">{entry.data.personName}</strong>
      <span class="role">{entry.data.personRole}</span>
      <span class="firma">{entry.data.clientName}</span>
    </div>

    {
      entry.data.tags.length > 0 && (
        <ul class="tags" aria-label={t("caseStudies.tagsLabel")}>
          {entry.data.tags.map((tag) => (
            <li class="relative z-[2]">
              <Badge>{tag}</Badge>
            </li>
          ))}
        </ul>
      )
    }

    <span class="read-more">
      {t("caseStudies.readMore")}
      <ArrowRight class="w-4 h-4" aria-hidden="true" />
    </span>
  </div>
</article>

<style>
  .case-study-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    color: inherit;
    transition: border-color var(--transition-fast) var(--ease-default);
  }

  .case-study-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    text-indent: -9999px;
    overflow: hidden;
    border-radius: inherit;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .thumbnail {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-surface);
  }

  .video-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: var(--color-accent);
    color: var(--color-text-on-dark);
    box-shadow: 0 2px 8px
      color-mix(in srgb, var(--color-surface-dark) 18%, transparent);
  }

  .thumbnail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-default);
  }

  .thumbnail--contain {
    background: var(--color-surface);
    padding: 1.5rem;
  }

  .thumbnail--contain .thumbnail-img {
    object-fit: contain;
  }

  .case-study-card:hover .thumbnail-img {
    transform: scale(1.04);
  }

  .case-study-card:hover .thumbnail--contain .thumbnail-img {
    transform: none;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    flex: 1;
  }

  .category {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .quote {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-heading);
    margin: 0;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .name {
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .role,
  .firma {
    color: var(--color-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: auto;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    transition: gap var(--transition-fast) var(--ease-default);
  }

  .case-study-card:hover .read-more {
    gap: 0.75rem;
  }
</style>

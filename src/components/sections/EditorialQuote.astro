---
import { Image } from "astro:assets";
import Section from "~/components/Section.astro";
import type { EditorialQuoteProps } from "~/types/sections";

type Props = EditorialQuoteProps;

const { quote, attribution, tone = "surface", padding = "lg" } = Astro.props;
---

<Section tone={tone} padding={padding} container="narrow">
  <figure class="pf-quote">
    <blockquote class="pf-quote__body text-h1">
      {quote}
    </blockquote>

    <figcaption class="pf-quote__attribution">
      {
        attribution.avatar && attribution.avatarAlt && (
          <Image
            src={attribution.avatar}
            alt={attribution.avatarAlt}
            width={48}
            height={48}
            class="pf-quote__avatar"
          />
        )
      }
      <div class="pf-quote__attribution-meta">
        <span class="pf-quote__name">{attribution.name}</span>
        {
          attribution.role && (
            <span class="pf-quote__role">{attribution.role}</span>
          )
        }
      </div>
    </figcaption>
  </figure>
</Section>

<style>
  .pf-quote {
    position: relative;
    margin: 0;
    padding-block-start: var(--space-12);
  }

  .pf-quote::before {
    content: "\201C";
    position: absolute;
    top: 0;
    left: -0.25em;
    font-family: var(--font-heading);
    font-size: var(--text-display);
    font-weight: 800;
    line-height: 1;
    opacity: 0.15;
    color: var(--color-accent);
    pointer-events: none;
  }

  .pf-quote__body {
    margin: 0;
    quotes: none;
    font-style: italic;
    color: var(--color-text-heading);
  }

  .pf-quote__body::before,
  .pf-quote__body::after {
    content: none;
  }

  .pf-quote__attribution {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .pf-quote__avatar {
    border-radius: 9999px;
    width: 3rem;
    height: 3rem;
    object-fit: cover;
    flex-shrink: 0;
  }

  .pf-quote__attribution-meta {
    display: flex;
    flex-direction: column;
    line-height: var(--leading-caption);
  }

  .pf-quote__name {
    font-weight: 700;
    color: var(--color-text-heading);
  }

  .pf-quote__role {
    color: var(--color-muted);
    font-size: var(--text-body-sm);
  }
</style>

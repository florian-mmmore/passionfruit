---
import { ChevronDown } from "@lucide/astro";
import Section from "~/components/Section.astro";
import type { FAQProps } from "~/types/sections";

type Props = FAQProps;

const {
  eyebrow,
  headline,
  lede,
  items,
  tone = "surface",
  padding = "lg",
  align = "center",
} = Astro.props;
---

<Section tone={tone} padding={padding} container="narrow">
  {
    (eyebrow || headline || lede) && (
      <header
        class:list={[
          "pf-faq__header",
          align === "center" && "pf-faq__header--center",
        ]}
      >
        {eyebrow && <span class="text-eyebrow pf-faq__eyebrow">{eyebrow}</span>}
        {headline && <h2 class="text-h2 pf-faq__title">{headline}</h2>}
        {lede && <p class="text-body-lg pf-faq__lede">{lede}</p>}
      </header>
    )
  }

  <ul role="list" class="pf-faq__list">
    {
      items.map((item) => (
        <li class="pf-faq__item">
          <details class="pf-faq__details">
            <summary class="pf-faq__summary">
              <span class="pf-faq__question">{item.question}</span>
              <ChevronDown
                size={18}
                class="pf-faq__chevron"
                aria-hidden="true"
              />
            </summary>
            <div class="pf-faq__answer">{item.answer}</div>
          </details>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .pf-faq__header {
    margin-bottom: var(--space-12);
    max-width: 48rem;
  }
  .pf-faq__header--center {
    margin-inline: auto;
    text-align: center;
  }
  .pf-faq__eyebrow {
    display: inline-block;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    color: var(--color-accent);
  }
  .pf-faq__title {
    margin: 0 0 var(--space-4) 0;
  }
  .pf-faq__lede {
    margin: 0;
    color: var(--color-muted);
  }

  .pf-faq__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pf-faq__details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-surface-elevated);
  }

  .pf-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text-heading);
    user-select: none;
    list-style: none;
    min-height: 44px;
    transition: background-color var(--transition-fast) var(--ease-default);
  }
  .pf-faq__summary::-webkit-details-marker {
    display: none;
  }
  .pf-faq__summary:hover {
    background-color: color-mix(
      in srgb,
      var(--color-text-heading) 4%,
      transparent
    );
  }
  .pf-faq__summary:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 2px var(--color-accent);
  }

  .pf-faq__question {
    flex: 1;
  }

  .pf-faq__chevron {
    flex-shrink: 0;
    color: var(--color-muted);
    transition: transform var(--transition-fast) var(--ease-default);
  }

  .pf-faq__details[open] .pf-faq__chevron {
    transform: rotate(180deg);
  }

  .pf-faq__answer {
    padding: var(--space-2) var(--space-6) var(--space-6);
    color: var(--color-text);
    line-height: var(--leading-body);
    border-top: 1px solid var(--color-border);
  }
</style>

# PostHog Analytics (EU instance)
# Leave PUBLIC_POSTHOG_API_KEY empty to disable — zero runtime cost when absent.
# Note: PUBLIC_POSTHOG_HOST is the ingest endpoint (eu.i.posthog.com),
# PUBLIC_POSTHOG_UI_HOST is the dashboard (eu.posthog.com) — used for toolbar/heatmap deep links.
PUBLIC_POSTHOG_API_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# Google Analytics 4 (gtag.js)
# Leave empty to disable. Format: G-XXXXXXXXXX (find it in GA4 → Admin → Data Streams).
# Consent-gated via the cookie banner; uses Consent Mode v2 (no ads cookies).
PUBLIC_GA_MEASUREMENT_ID=

# Site URL (used for sitemap, canonical URLs, structured data)
SITE_URL=https://example.com

# OpenAI API key (for image generation via pnpm generate-image)
# Only needed if you want to generate images with GPT Image models
OPENAI_API_KEY=

# PostHog Analytics (EU instance)
# Leave PUBLIC_POSTHOG_API_KEY empty to disable — zero runtime cost when absent.
# Note: PUBLIC_POSTHOG_HOST is the ingest endpoint (eu.i.posthog.com),
# PUBLIC_POSTHOG_UI_HOST is the dashboard (eu.posthog.com) — used for toolbar/heatmap deep links.
PUBLIC_POSTHOG_API_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# Google Analytics 4 (gtag.js)
# Leave empty to disable. Format: G-XXXXXXXXXX (find it in GA4 → Admin → Data Streams).
# Consent-gated via the cookie banner; uses Consent Mode v2 (no ads cookies).
PUBLIC_GA_MEASUREMENT_ID=

# Site URL (used for sitemap, canonical URLs, structured data)
SITE_URL=https://example.com

# OpenAI API key (for image generation via pnpm generate-image)
# Only needed if you want to generate images with GPT Image models
OPENAI_API_KEY=

# Contact form delivery
# PUBLIC_FORM_ENDPOINT controls how the contact form submits:
#   unset          → mailto fallback (opens visitor's mail client; zero config)
#   /api/contact   → bundled Cloudflare Pages Function (verifies + emails via Brevo)
#   any other URL  → BYO external form service (receives { name, email, message, honeypot, turnstileToken } JSON via POST)
# IMPORTANT: if you point PUBLIC_FORM_ENDPOINT at an external (non-/api/contact) URL, you must also add that
# endpoint's host to the connect-src directive in public/_headers, or the browser will silently block the request.
PUBLIC_FORM_ENDPOINT=

# Public Turnstile sitekey (spam protection for the /api/contact function tier).
# PUBLIC_TURNSTILE_SITE_KEY (build-time, public) and TURNSTILE_SECRET_KEY (server secret) must be set TOGETHER:
#   - sitekey only → widget renders but server skips verification (no real protection)
#   - secret only  → no widget renders (token is never sent)
# Leave both empty to skip Turnstile entirely — honeypot is still active.
PUBLIC_TURNSTILE_SITE_KEY=

# The following are server-only secrets — set them as Cloudflare Pages secrets
# at deploy time (Settings → Environment variables → Add secret). Never commit
# them here or use PUBLIC_* prefixes.
#
#   CONTACT_RECIPIENT    — email address where form submissions are delivered
#   CONTACT_SENDER       — Brevo-verified sender address (appears in From:)
#   BREVO_API_KEY        — Brevo transactional email API key
#   TURNSTILE_SECRET_KEY — Cloudflare Turnstile secret key (server-side verify)
#   CONTACT_SENDER_NAME  — optional; overrides the From: display name (default: "Website contact form")
